@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Inicio</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2>Bienvenido al Sistema de Gestión de Planta Docente</h2>
            <hr />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("docentes")'>
                <div class="card-body">
                    <h5 class="card-title">👥 Docentes</h5>
                    <p class="card-text">Gestión del plantel docente</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("designaciones")'>
                <div class="card-body">
                    <h5 class="card-title">📋 Designaciones</h5>
                    <p class="card-text">Asignaciones de docentes a cargos</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-info mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("udbs")'>
                <div class="card-body">
                    <h5 class="card-title">🏫 UDBs</h5>
                    <p class="card-text">Unidades Docentes Básicas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("cargos")'>
                <div class="card-body">
                    <h5 class="card-title">💼 Cargos</h5>
                    <p class="card-text">Tipos de cargos docentes</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-secondary mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("dedicaciones")'>
                <div class="card-body">
                    <h5 class="card-title">🕐 Dedicaciones</h5>
                    <p class="card-text">Tipos de dedicación horaria</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-dark mb-3" style="cursor:pointer"
                 @onclick='() => Navigation.NavigateTo("cursos")'>
                <div class="card-body">
                    <h5 class="card-title">🎓 Cursos</h5>
                    <p class="card-text">Cursos y comisiones</p>
                </div>
            </div>
        </div>
    </div>
</div>