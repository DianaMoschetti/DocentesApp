@page "/docentes"
@using DocentesApp.Shared.DTOs.Docentes
@attribute [Authorize]
@rendermode InteractiveServer
@inject IClient Client
@inject NavigationManager Navigation

<PageTitle>Docentes</PageTitle>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>👥 Docentes</h2>
        </div>
        <div class="col text-end">
            <button class="btn btn-primary"
                    @onclick='() => Navigation.NavigateTo("docentes/nuevo")'>
                + Nuevo Docente
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <p>Cargando...</p>
    }
    else if (_errorMessage != null)
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    else if (!_docentes.Any())
    {
        <div class="alert alert-info">No hay docentes registrados.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Legajo</th>
                    <th>Nombre completo</th>
                    <th>DNI</th>
                    <th>Email</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var docente in _docentes)
                {
                    <tr>
                        <td>@docente.Legajo</td>
                        <td>@docente.NombreCompleto</td>
                        <td>@docente.Dni</td>
                        <td>@docente.Email</td>
                        <td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    @onclick="@(() => Navigation.NavigateTo($"docentes/{docente.Id}"))">
                                Ver
                            </button>
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    @onclick="@(() => Navigation.NavigateTo($"docentes/{docente.Id}/editar"))">
                                Editar
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="@(() => ConfirmarEliminar(docente.Id, docente.NombreCompleto))">
                                Eliminar
                            </button>
                        </td>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_mostrarConfirmacion)
    {
        <div class="modal d-block" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmar eliminación</h5>
                    </div>
                    <div class="modal-body">
                        ¿Estás segura que querés eliminar a <strong>@_nombreAEliminar</strong>?
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary"
                                @onclick="() => _mostrarConfirmacion = false">
                            Cancelar
                        </button>
                        <button class="btn btn-danger" @onclick="EliminarDocente">
                            Eliminar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ICollection<ListDocenteDto> _docentes = new List<ListDocenteDto>();
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool _mostrarConfirmacion;
    private int _idAEliminar;
    private string? _nombreAEliminar;

    protected override async Task OnInitializedAsync()
    {
        await CargarDocentes();
    }

    private async Task CargarDocentes()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _docentes = await Client.DocentesAllAsync();
        }
        catch (ApiException ex)
        {
            _errorMessage = ex.StatusCode == 401
                ? "No tenés permisos para ver esta sección."
                : "Error al cargar los docentes. Intentá de nuevo.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ConfirmarEliminar(int id, string? nombre)
    {
        _idAEliminar = id;
        _nombreAEliminar = nombre;
        _mostrarConfirmacion = true;
    }

    private async Task EliminarDocente()
    {
        try
        {
            await Client.DocentesDELETEAsync(_idAEliminar);
            _mostrarConfirmacion = false;
            await CargarDocentes();
        }
        catch (ApiException ex)
        {
            _mostrarConfirmacion = false;
            _errorMessage = ex.StatusCode == 409
                ? "No se puede eliminar el docente porque tiene designaciones asociadas."
                : "Error al eliminar el docente.";
        }
    }
}