@page "/docentes/nuevo"
@page "/docentes/{Id:int}/editar"
@using DocentesApp.Blazor.UI.Helpers
@using DocentesApp.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer
@inject IClient Client
@inject NavigationManager Navigation

<!-- Si id= null, create. si id <> null edit.
    -->

<PageTitle>@(esEdicion ? "Editar Docente" : "Nuevo Docente")</PageTitle>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>@(esEdicion ? "✏️ Editar Docente" : "➕ Nuevo Docente")</h2>
        </div>
        <div class="col text-end">
            <button class="btn btn-secondary"
                    @onclick='() => Navigation.NavigateTo("docentes")'>
                ← Volver
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <p>Cargando...</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="card">
            <div class="card-body">
                    <EditForm Model="docenteDto" OnSubmit="HandleSubmit">                   

                    <h5 class="mb-3">Datos personales</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="docenteDto.Nombre" />
                                <ValidationMessage For="@(() => docenteDto.Nombre)" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Apellido <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="docenteDto.Apellido" />
                                <ValidationMessage For="@(() => docenteDto.Apellido)" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">DNI <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="docenteDto.Dni" />
                                <ValidationMessage For="@(() => docenteDto.Dni)" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Legajo <span class="text-danger">*</span></label>
                                <InputNumber class="form-control" @bind-Value="docenteDto.Legajo" />
                                <ValidationMessage For="@(() => docenteDto.Legajo)" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Fecha de nacimiento</label>
                                <InputText class="form-control" @bind-Value="docenteDto.FechaNacimiento"
                                       placeholder="yyyy-MM-dd" />
                        </div>
                    </div>

                    <h5 class="mb-3 mt-2">Contacto</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="docenteDto.Email" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email alternativo</label>
                                <InputText class="form-control" @bind-Value="docenteDto.EmailAlternativo" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Celular</label>
                                <InputText class="form-control" @bind-Value="docenteDto.Celular" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Dirección</label>
                                <InputText class="form-control" @bind-Value="docenteDto.Direccion" />
                        </div>
                    </div>

                    <h5 class="mb-3 mt-2">Académico</h5>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Máximo nivel académico <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="docenteDto.MaxNivelAcademico">
                            <option value="">-- Seleccionar --</option>
                            @foreach (var (value, display) in titulos)
                            {
                                <option value="@((int)value)">@display</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => docenteDto.MaxNivelAcademico)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Observaciones</label>
                            <InputTextArea class="form-control" @bind-Value="docenteDto.Observaciones" rows="3" />
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <span>@(esEdicion ? "Guardar cambios" : "Crear docente")</span>
                            }
                        </button>
                    </div>

                </EditForm>
            </div>
        </div>
    }
</div>

@code {

    [Parameter] public int? Id { get; set; } // Si es null, es creación. Si tiene valor, es edición.
    private CreateDocenteDto docenteDto = new();
    private bool esEdicion => Id.HasValue;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private readonly List<(Domain.Enums.Titulo Value, string Display)> titulos = EnumHelper.GetOptions<Domain.Enums.Titulo>();

    protected override async Task OnParametersSetAsync()
    {
        // OnParametersSetAsync en vez de OnInitializedAsync pq cuando navega de /docentes/nuevo a /docentes/5/editar
        // el componente no se destruye y recrea, solo cambian los parámetros
        if (esEdicion)
        {
            await CargarDocente();
        }
        else
        {
            docenteDto = new CreateDocenteDto();
            isLoading = false;
        }
    }

    private async Task CargarDocente()
    {
        try
        {
            isLoading = true;
            var docente = await Client.DocentesGETAsync(Id!.Value);

            docenteDto = new CreateDocenteDto
            {
                Nombre = docente.Nombre ?? "",
                Apellido = docente.Apellido ?? "",
                Dni = docente.Dni ?? "",
                Legajo = docente.Legajo,
                Email = docente.Email,
                EmailAlternativo = docente.EmailAlternativo,
                Celular = docente.Celular,
                Direccion = docente.Direccion,
                MaxNivelAcademico = (DocentesApp.Blazor.UI.Services.Base.Titulo)docente.MaxNivelAcademico,
                Observaciones = docente.Observaciones
            };
        }
        catch (ApiException)
        {
            errorMessage = "No se pudo cargar el docente.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            if (esEdicion)
            {
                var updateDto = new UpdateDocenteDto
                {
                    Nombre = docenteDto.Nombre,
                    Apellido = docenteDto.Apellido,
                    Dni = docenteDto.Dni,
                    Legajo = docenteDto.Legajo,
                    Email = docenteDto.Email,
                    EmailAlternativo = docenteDto.EmailAlternativo,
                    Celular = docenteDto.Celular,
                    Direccion = docenteDto.Direccion,
                    MaxNivelAcademico = docenteDto.MaxNivelAcademico,
                    Observaciones = docenteDto.Observaciones
                };
                await Client.DocentesPUTAsync(Id!.Value, updateDto);
                Navigation.NavigateTo("docentes",
                    new NavigationOptions { ReplaceHistoryEntry = true });
            }
            else
            {
                await Client.DocentesPOSTAsync(docenteDto);
                Navigation.NavigateTo("docentes",
                    new NavigationOptions { ReplaceHistoryEntry = true });
            }
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == 400)
            {
                // extraer errores de validación del JSON de respuesta
                try
                {
                    var errorResponse = System.Text.Json.JsonSerializer.Deserialize<ValidationErrorResponse>(
                        ex.Response,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                    if (errorResponse?.Errors != null && errorResponse.Errors.Any())
                    {
                        // Armamos un mensaje con todos los errores
                        errorMessage = string.Join(" | ",
                            errorResponse.Errors.SelectMany(e => e.Value));
                    }
                    else
                    {
                        errorMessage = ex.Response; // mostramos el JSON crudo si no podemos parsearlo
                    }
                }
                catch
                {
                    errorMessage = ex.Response; // fallback al texto crudo
                }
            }
            else
            {
                errorMessage = ex.StatusCode switch
                {
                    401 => "No tiene permisos para realizar esta acción.",
                    403 => "No tiene permisos para realizar esta acción.",
                    409 => "Ya existe un docente con ese DNI o legajo.",
                    _ => "Error al guardar. Intentá de nuevo."
                };
            }
        }
        finally
        {
            isSaving = false;
        }
    }
       

    private class ValidationErrorResponse
    {
        public Dictionary<string, string[]>? Errors { get; set; }
    }
}